{
  "version": 1,
  "mode": "sequential",
  "fail_fast": true,
  "vars": {
    "base_url": "https://httpbin.org"
  },
  "steps": {
    "get_test": {
      "request": {
        "method": "GET",
        "url": "${base_url}/get",
        "params": {
          "name": "test",
          "age": "25"
        }
      },
      "extract": {
        "param_name": "$.args.name",
        "param_age": {
          "jsonpath": "$.args.age"
        }
      },
      "validate": [
        { "eq": ["$.args.name", "test"] },
        { "eq": ["$.args.age", "25"] },
        { "in": ["$.args.name", ["test", "demo"]] },
        { "len_eq": ["$.args.name", 4] }
      ]
    },
    "post_json": {
      "request": {
        "method": "POST",
        "url": "${base_url}/post",
        "json": {
          "username": "admin",
          "password": "123456"
        }
      },
      "extract": {
        "request_body": "$.json",
        "password_suffix": {
          "regex": "\"password\":\"([0-9]+)\"",
          "group": 1
        }
      },
      "validate": [
        { "eq": ["$.json.username", "admin"] },
        { "starts_with": ["$.json.username", "ad"] },
        { "ends_with": ["$.json.password", "456"] },
        { "matches": ["$.json.username", "^adm"] },
        { "not_contains": ["$.json.username", "guest"] }
      ]
    },
    "post_form": {
      "request": {
        "method": "POST",
        "url": "${base_url}/post",
        "form": {
          "field1": "value1",
          "field2": "value2"
        }
      },
      "validate": [
        { "eq": ["$.form.field1", "value1"] }
      ]
    },
    "post_raw": {
      "request": {
        "method": "POST",
        "url": "${base_url}/post",
        "body": "<root><name>test</name></root>",
        "content_type": "application/xml"
      },
      "validate": [
        { "eq": ["$.data", "<root><name>test</name></root>"] }
      ]
    },
    "dependent_step": {
      "depends_on": ["get_test", "post_json"],
      "request": {
        "method": "GET",
        "url": "${base_url}/get",
        "params": {
          "ref": "${param_name}"
        }
      },
      "validate": [
        { "eq": ["$.args.ref", "test"] }
      ]
    },
    "custom_headers": {
      "request": {
        "method": "GET",
        "url": "${base_url}/headers",
        "headers": {
          "X-Custom-Header": "my-value",
          "Authorization": "Bearer token123"
        }
      },
      "validate": [
        { "contains": ["$.headers.X-Custom-Header", "my-value"] },
        { "contains": ["$.headers.Authorization", "Bearer"] }
      ]
    }
  }
}
